# Supabase — copy to .env and fill in from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Telegram notifications (optional)
VITE_TELEGRAM_NOTIFY_ENABLED=false
VITE_TELEGRAM_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/telegram-notify

# ─── Database setup (Supabase SQL Editor, in order) ───
# 1. supabase/schema.sql
# 2. supabase/migrations/002_storage_and_trade_fields.sql
# 3. supabase/migrations/001_anti_cheat_trigger.sql  (optional)
